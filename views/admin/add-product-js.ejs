// Size presets handling
const INCH_TO_MM = 25.4;

// Initialize size presets from localStorage or use defaults
let sizePresets = JSON.parse(localStorage.getItem('sizePresets')) || {
    standard: { name: 'Standard US', width: 3.5, height: 2, multiplier: 1 },
    euro: { name: 'European', width: 3.346, height: 2.165, multiplier: 1 }, // 85mm × 55mm
    square: { name: 'Square', width: 2.5, height: 2.5, multiplier: 1.1 },
    mini: { name: 'Mini', width: 2.5, height: 1.5, multiplier: 0.8 },
    folded: { name: 'Folded', width: 3.5, height: 4, multiplier: 1.75 }
};

// Function to save presets to localStorage
function savePresets() {
    localStorage.setItem('sizePresets', JSON.stringify(sizePresets));
}

// Function to update the presets dropdown
function updatePresetsDropdown() {
    const presetsList = document.getElementById('sizePresetsList');
    presetsList.innerHTML = '';
    
    Object.entries(sizePresets).forEach(([key, preset]) => {
        const li = document.createElement('li');
        li.innerHTML = `
            <div class="dropdown-item d-flex justify-content-between align-items-center">
                <a href="#" class="text-decoration-none text-dark flex-grow-1" onclick="applyPreset('${key}'); return false;">
                    ${preset.name} (${preset.width}" × ${preset.height}")
                </a>
                <button class="btn btn-link text-danger p-0 ms-2" 
                        onclick="deletePreset('${key}'); return false;">
                    <small>Delete</small>
                </button>
            </div>
        `;
        presetsList.appendChild(li);
    });
}

// Function to show the add preset modal
function showAddPresetModal() {
    const modal = new bootstrap.Modal(document.getElementById('addPresetModal'));
    modal.show();
}

// Function to save a new preset
function saveNewPreset() {
    const name = document.getElementById('presetName').value.trim();
    const width = parseFloat(document.getElementById('presetWidth').value);
    const height = parseFloat(document.getElementById('presetHeight').value);
    const multiplier = parseFloat(document.getElementById('presetMultiplier').value);

    if (!name || !width || !height || !multiplier) {
        alert('Please fill in all fields');
        return;
    }

    const key = name.toLowerCase().replace(/[^a-z0-9]/g, '_');
    
    sizePresets[key] = {
        name: name,
        width: width,
        height: height,
        multiplier: multiplier
    };

    savePresets();
    updatePresetsDropdown();

    // Close modal and reset form
    const modal = bootstrap.Modal.getInstance(document.getElementById('addPresetModal'));
    modal.hide();
    document.getElementById('presetForm').reset();
}

// Function to delete a preset
function deletePreset(key) {
    if (confirm(`Are you sure you want to delete the "${sizePresets[key].name}" preset?`)) {
        delete sizePresets[key];
        savePresets();
        updatePresetsDropdown();
    }
}

// Paper selection handling
document.getElementById('selectAllPapers').addEventListener('change', function() {
    const checkboxes = document.querySelectorAll('.paper-checkbox');
    checkboxes.forEach(checkbox => {
        checkbox.checked = this.checked;
        const paperData = JSON.parse(checkbox.dataset.paper);
        if (this.checked) {
            selectedPapers.set(paperData.id, paperData);
        } else {
            selectedPapers.delete(paperData.id);
        }
    });
    updateSelectedPapersTable();
});

// Individual paper checkbox handling
document.querySelectorAll('.paper-checkbox').forEach(checkbox => {
    checkbox.addEventListener('change', function() {
        const paperData = JSON.parse(this.dataset.paper);
        if (this.checked) {
            selectedPapers.set(paperData.id, paperData);
        } else {
            selectedPapers.delete(paperData.id);
        }
        updateSelectedPapersTable();
    });
});

function confirmPaperSelection() {
    updateSelectedPapersTable();
    document.getElementById('selectedPaperIds').value = Array.from(selectedPapers.keys()).join(',');
    const modal = bootstrap.Modal.getInstance(document.getElementById('paperSelectionModal'));
    modal.hide();
    // Update number up calculations for all size entries
    updateAllNumberUp();
}

function updateSelectedPapersTable() {
    const tbody = document.getElementById('selectedPapersList');
    tbody.innerHTML = '';
    
    selectedPapers.forEach(paper => {
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${paper.name}</td>
            <td><span class="badge ${paper.category === 'premium' ? 'bg-primary' : 'bg-success'}">${paper.category}</span></td>
            <td>${paper.thickness}</td>
            <td>${paper.finish}</td>
            <td>$${paper.upgradeCost}</td>
        `;
        tbody.appendChild(row);
    });
}

function calculateNumberUp(width, height, parentWidth, parentHeight) {
    if (!width || !height || !parentWidth || !parentHeight) return 0;

    const bleed = 0.125;
    const jobWidth = parseFloat(width) + (bleed * 2);
    const jobHeight = parseFloat(height) + (bleed * 2);

    const acrossSheet = Math.floor(parentWidth / jobWidth);
    const downSheet = Math.floor(parentHeight / jobHeight);

    return acrossSheet * downSheet;
}

function updateNumberUp(sizeEntry) {
    const width = sizeEntry.querySelector('.size-width').value;
    const height = sizeEntry.querySelector('.size-height').value;
    const displaySpan = sizeEntry.querySelector('.number-up-display');

    if (!width || !height) {
        displaySpan.innerHTML = '<span class="text-muted">Enter dimensions</span>';
        return;
    }

    if (selectedPapers.size === 0) {
        displaySpan.innerHTML = '<span class="text-muted">Select papers first</span>';
        return;
    }

    let html = '';
    selectedPapers.forEach(paper => {
        const numberUp = calculateNumberUp(width, height, paper.parentSheetSize.width, paper.parentSheetSize.height);
        html += `<div><strong>${paper.name}:</strong> ${numberUp} up</div>`;
    });

    displaySpan.innerHTML = html;
}

function updateAllNumberUp() {
    document.querySelectorAll('.size-entry').forEach(sizeEntry => {
        updateNumberUp(sizeEntry);
    });
}

function applyPreset(presetKey) {
    const presetData = sizePresets[presetKey];
    if (!presetData) return;

    const firstSizeEntry = document.querySelector('.size-entry');
    if (!firstSizeEntry) {
        addSizeEntry();
        return;
    }

    const nameInput = firstSizeEntry.querySelector('input[name$="[name]"]');
    const widthInput = firstSizeEntry.querySelector('input[name$="[width]"]');
    const heightInput = firstSizeEntry.querySelector('input[name$="[height]"]');
    const multiplierInput = firstSizeEntry.querySelector('input[name$="[priceMultiplier]"]');

    nameInput.value = presetData.name;
    widthInput.value = presetData.width;
    heightInput.value = presetData.height;
    multiplierInput.value = presetData.multiplier;

    updateNumberUp(firstSizeEntry);
}

