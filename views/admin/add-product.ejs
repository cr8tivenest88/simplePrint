        function addUpgradeEntry() {
            const container = document.getElementById('upgradesContainer');
            const template = `
                <div class="upgrade-entry border rounded p-3 mb-2">
                    <div class="row">
                        <div class="col-md-5">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" name="upgrades[${upgradeCount}][name]" required>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Upgrade Cost</label>
                            <input type="number" class="form-control" name="upgrades[${upgradeCount}][upgradeCost]" step="0.01" required>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-danger btn-sm" onclick="removeUpgrade(this)">Remove</button>
                        </div>
                    </div>
                    <div class="row mt-2">
