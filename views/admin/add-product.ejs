<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Product - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/admin/dashboard">Admin Dashboard</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/admin/products/add">Add Product</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/logout">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <h2 class="mb-4">Add New Product</h2>
                <div class="card">
                    <div class="card-body">
                        <div id="errorAlert" class="alert alert-danger d-none" role="alert">
                            <strong>Fix the following:</strong>
                            <ul id="errorList" class="mb-0"></ul>
                        </div>
                        <form action="/admin/products" method="POST" id="addProductForm">
                            <!-- Basic Information -->
                            <div class="mb-4">
                                <h5>Basic Information</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Product Name</label>
                                            <input type="text" class="form-control" name="name" required>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Description (Optional)</label>
                                    <textarea class="form-control" name="description" rows="3" placeholder="WordPress will handle product descriptions"></textarea>
                                </div>
                            </div>

                            <!-- Click Costs -->
                            <div class="mb-4">
                                <h5 class="mb-3">Click Costs (Per Item)</h5>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Color ($)</label>
                                            <input type="number" step="0.01" class="form-control" name="clickCosts[color]" value="0.10" required>
                                            <small class="text-muted">Cost per click for color printing (front and back)</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Black ($)</label>
                                            <input type="number" step="0.01" class="form-control" name="clickCosts[black]" value="0.05" required>
                                            <small class="text-muted">Cost per click for black printing (front and back)</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Paper Types -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="mb-0">Available Papers</h5>
                                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#paperSelectionModal">
                                        Select Papers
                                    </button>
                                </div>
                                <div id="selectedPapersContainer" class="table-responsive">
                                    <table class="table table-bordered">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Name</th>
                                                <th>Category</th>
                                                <th>Thickness</th>
                                                <th>Finish</th>
                                                <th>Upgrade Cost</th>
                                            </tr>
                                        </thead>
                                        <tbody id="selectedPapersList">
                                            <!-- Selected papers will be displayed here -->
                                        </tbody>
                                    </table>
                                </div>
                                <!-- Hidden input to store selected paper IDs -->
                                <input type="hidden" name="selectedPaperIds" id="selectedPaperIds" value="">
                            </div>

                            <!-- Paper Selection Modal -->
                            <div class="modal fade" id="paperSelectionModal" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Select Papers for Product</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="table-responsive">
                                                <table class="table table-hover">
                                                    <thead>
                                                        <tr>
                                                            <th>
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox" id="selectAllPapers">
                                                                </div>
                                                            </th>
                                                            <th>Name</th>
                                                            <th>Category</th>
                                                            <th>Thickness</th>
                                                            <th>Finish</th>
                                                            <th>Parent Sheet</th>
                                                            <th>Cost/Sheet</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% papers.forEach(paper => { %>
                                                            <tr>
                                                                <td>
                                                                    <div class="form-check">
                                                                        <input class="form-check-input paper-checkbox"
                                                                               type="checkbox"
                                                                               value="<%= paper.id %>"
                                                                               data-paper-id="<%= paper.id %>">
                                                                    </div>
                                                                </td>
                                                                <td><%= paper.name %></td>
                                                                <td><span class="badge <%= paper.category === 'premium' ? 'bg-primary' : 'bg-success' %>">
                                                                    <%= paper.category %>
                                                                </span></td>
                                                                <td><%= paper.thickness %></td>
                                                                <td><%= paper.finish %></td>
                                                                <td><%= paper.parentSheetSize.width %>" × <%= paper.parentSheetSize.height %>"</td>
                                                                <td>$<%= paper.costPerSheet.toFixed(4) %></td>
                                                            </tr>
                                                        <% }); %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="button" class="btn btn-primary" onclick="confirmPaperSelection()">Confirm Selection</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Sizes -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="mb-0">Card Sizes</h5>
                                    <div>
                                        <div class="dropdown d-inline-block me-2">
                                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="sizePresetsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                                Size Presets
                                            </button>
                                            <ul class="dropdown-menu" id="sizePresetsList" aria-labelledby="sizePresetsDropdown">
                                                <!-- Presets will be populated by JavaScript -->
                                            </ul>
                                        </div>
                                        <button type="button" class="btn btn-outline-primary btn-sm me-2" onclick="addSizeEntry()">Add Custom Size</button>
                                        <button type="button" class="btn btn-outline-success btn-sm" onclick="showAddPresetModal()">Add New Preset</button>
                                    </div>

                                </div>
                                <div id="sizesContainer">
                                    <div class="size-entry border rounded p-3 mb-2">
                                        <div class="row">
                                            <div class="col-md-2">
                                                <label class="form-label">Name</label>
                                                <input type="text" class="form-control" name="sizes[0][name]" placeholder="e.g., Standard" required>
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">Width (inches)</label>
                                                <input type="number" class="form-control size-width" name="sizes[0][width]" step="0.125" required>
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">Height (inches)</label>
                                                <input type="number" class="form-control size-height" name="sizes[0][height]" step="0.125" required>
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">Price Multiplier</label>
                                                <input type="number" class="form-control" name="sizes[0][priceMultiplier]" step="0.1" required>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Number Up per Paper</label>
                                                <div class="form-control-plaintext">
                                                    <span class="number-up-display text-muted">Select papers and enter dimensions</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Upgrades -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="mb-0">Upgrades</h5>
                                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="addUpgradeEntry()">
                                        Add Upgrade
                                    </button>
                                </div>
                                <div id="upgradesContainer">
                                    <% upgrades.forEach((upgrade, index) => { %>
                                        <div class="upgrade-entry border rounded p-3 mb-2">
                                            <div class="row">
                                                <div class="col-md-5">
                                                    <label class="form-label">Name</label>
                                                    <input type="text" class="form-control" name="upgrades[<%= index %>][name]" value="<%= upgrade.name %>" required>
                                                </div>
                                                <div class="col-md-5">
                                                    <label class="form-label">Upgrade Cost</label>
                                                    <input type="number" class="form-control" name="upgrades[<%= index %>][upgradeCost]" value="<%= upgrade.upgradeCost %>" step="0.01" required>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-end">
                                                    <button type="button" class="btn btn-danger btn-sm" onclick="removeUpgrade(this)">Remove</button>
                                                </div>
                                            </div>
                                            <div class="row mt-2">
                                                <div class="col-12">
                                                    <label class="form-label">Description</label>
                                                    <textarea class="form-control" name="upgrades[<%= index %>][description]" required><%= upgrade.description %></textarea>
                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>

                            <!-- Quantity Prices -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div>
                                        <h5 class="mb-0">Quantity Pricing</h5>
                                        <small class="text-muted">Enter quantity to auto-calculate all fields including price. You can manually edit price after calculation.</small>
                                    </div>
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-success btn-sm" onclick="autoCalculateAllPrices()">
                                            <i class="bi bi-calculator"></i> Auto-Calculate Prices
                                        </button>
                                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="addQuantityPrice()">
                                            Add Quantity Price
                                        </button>
                                    </div>
                                </div>
                                <div id="quantityPricesContainer" class="table-responsive">
                                    <table class="table table-bordered table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Quantity</th>
                                                <th>Sheets</th>
                                                <th>Paper Cost</th>
                                                <th>Click Cost</th>
                                                <th>Total Cost</th>
                                                <th>Markup %</th>
                                                <th>Price ($)</th>
                                                <th>$/Card</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm quantity-input"
                                                           name="quantityPrices[0][quantity]"
                                                           value="50" required
                                                           oninput="autoCalculateRowPrice(this)">
                                                </td>
                                                <td class="sheets-display">-</td>
                                                <td class="paper-cost-display">-</td>
                                                <td class="click-cost-display">-</td>
                                                <td class="total-cost-display">-</td>
                                                <td class="markup-display">-</td>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm price-input"
                                                           name="quantityPrices[0][price]"
                                                           value="15" step="0.01" required
                                                           onchange="updatePricePerCard(this)">
                                                </td>
                                                <td>
                                                    <span class="price-per-card">$0.30</span>
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-danger btn-sm" onclick="removeQuantityPrice(this)">
                                                        Remove
                                                    </button>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm quantity-input"
                                                           name="quantityPrices[1][quantity]"
                                                           value="100" required
                                                           oninput="autoCalculateRowPrice(this)">
                                                </td>
                                                <td class="sheets-display">-</td>
                                                <td class="paper-cost-display">-</td>
                                                <td class="click-cost-display">-</td>
                                                <td class="total-cost-display">-</td>
                                                <td class="markup-display">-</td>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm price-input"
                                                           name="quantityPrices[1][price]"
                                                           value="20" step="0.01" required
                                                           onchange="updatePricePerCard(this)">
                                                </td>
                                                <td>
                                                    <span class="price-per-card">$0.20</span>
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-danger btn-sm" onclick="removeQuantityPrice(this)">
                                                        Remove
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="form-check mb-3">
                                <input type="checkbox" class="form-check-input" name="isActive" checked>
                                <label class="form-check-label">Active</label>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="/admin/dashboard" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary" id="createProductBtn">Create Product</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Preset Modal (moved outside main form) -->
    <div class="modal fade" id="addPresetModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Size Preset</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="presetForm">
                        <div class="mb-3">
                            <label class="form-label">Preset Name</label>
                            <input type="text" class="form-control" id="presetName" name="presetName">
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Width (inches)</label>
                                    <input type="number" class="form-control" id="presetWidth" name="presetWidth" step="0.125">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Height (inches)</label>
                                    <input type="number" class="form-control" id="presetHeight" name="presetHeight" step="0.125">
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Price Multiplier</label>
                            <input type="number" class="form-control" id="presetMultiplier" name="presetMultiplier" step="any" value="1">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="saveNewPreset()">Save Preset</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        console.log('=== SCRIPT LOADED AT:', new Date().toISOString(), '===')
        // Expose papers for calculator and selection helpers
        window.papers = <%- JSON.stringify(papers) %>;

        let sizeCount = 1;
        let upgradeCount = <%= upgrades.length %>;
        let selectedPapers = new Map();
        let quantityPriceCount = 2; // Start at 2 since we have two default entries

        // Paper selection handling
        document.getElementById('selectAllPapers').addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.paper-checkbox');
            checkboxes.forEach(checkbox => {
                checkbox.checked = this.checked;
                const id = checkbox.dataset.paperId;
                const paperData = window.papers.find(p => p.id === id);
                if (!paperData) return;
                if (this.checked) {
                    selectedPapers.set(paperData.id, paperData);
                } else {
                    selectedPapers.delete(paperData.id);
                }
            });
            updateSelectedPapersTable();
        });

        // Individual paper checkbox handling
        document.querySelectorAll('.paper-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const id = this.dataset.paperId;
                const paperData = window.papers.find(p => p.id === id);
                if (!paperData) return;
                if (this.checked) {
                    selectedPapers.set(paperData.id, paperData);
                } else {
                    selectedPapers.delete(paperData.id);
                }
                updateSelectedPapersTable();
            });
        });

        function confirmPaperSelection() {
            updateSelectedPapersTable();
            document.getElementById('selectedPaperIds').value = Array.from(selectedPapers.keys()).join(',');
            // Move focus away from a control before hiding to avoid aria-hidden focus issue
            if (document.activeElement && typeof document.activeElement.blur === 'function') {
                document.activeElement.blur();
            }
            const modal = bootstrap.Modal.getInstance(document.getElementById('paperSelectionModal'));
            modal.hide();
            // Return focus to the trigger button
            setTimeout(() => {
                const triggerBtn = document.querySelector('button[data-bs-target="#paperSelectionModal"]');
                if (triggerBtn) triggerBtn.focus();
            }, 0);
            // Update number up calculations for all size entries
            updateAllNumberUp();
        }

        function updateSelectedPapersTable() {
            const tbody = document.getElementById('selectedPapersList');
            tbody.innerHTML = '';

            selectedPapers.forEach(paper => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${paper.name}</td>
                    <td><span class="badge ${paper.category === 'premium' ? 'bg-primary' : 'bg-success'}">${paper.category}</span></td>
                    <td>${paper.thickness}</td>
                    <td>${paper.finish}</td>
                    <td>$${paper.upgradeCost}</td>
                `;
                tbody.appendChild(row);
            });
        }

        function calculateNumberUp(width, height, parentWidth, parentHeight) {
            if (!width || !height || !parentWidth || !parentHeight) return 0;

            const bleed = 0.125;
            const jobWidth = parseFloat(width) + (bleed * 2);
            const jobHeight = parseFloat(height) + (bleed * 2);

            const acrossSheet = Math.floor(parentWidth / jobWidth);
            const downSheet = Math.floor(parentHeight / jobHeight);

            return acrossSheet * downSheet;
        }

        function updateNumberUp(sizeEntry) {
            const width = sizeEntry.querySelector('.size-width').value;
            const height = sizeEntry.querySelector('.size-height').value;
            const displaySpan = sizeEntry.querySelector('.number-up-display');

            if (!width || !height) {
                displaySpan.innerHTML = '<span class="text-muted">Enter dimensions</span>';
                return;
            }

            if (selectedPapers.size === 0) {
                displaySpan.innerHTML = '<span class="text-muted">Select papers first</span>';
                return;
            }

            let html = '';
            selectedPapers.forEach(paper => {
                const numberUp = calculateNumberUp(width, height, paper.parentSheetSize.width, paper.parentSheetSize.height);
                html += `<div><strong>${paper.name}:</strong> ${numberUp} up</div>`;
            });

            displaySpan.innerHTML = html;
        }

        function updateAllNumberUp() {
            document.querySelectorAll('.size-entry').forEach(sizeEntry => {
                updateNumberUp(sizeEntry);
            });
        }

        const INCH_TO_MM = 25.4;
        
        // Initialize size presets from server
        let sizePresets = {};

        // Function to load presets from server
        async function loadPresets() {
            try {
                const response = await fetch('/admin/presets');
                if (response.ok) {
                    sizePresets = await response.json();
                    updatePresetsDropdown();
                }
            } catch (error) {
                console.error('Failed to load presets:', error);
            }
        }

        // Function to save presets to server
        async function savePresets() {
            // This function is no longer used for saving individual presets
            // Individual presets are saved via saveNewPreset()
        }

        // Function to update the presets dropdown
        function updatePresetsDropdown() {
            const presetsList = document.getElementById('sizePresetsList');
            presetsList.innerHTML = '';
            
            Object.entries(sizePresets).forEach(([key, preset]) => {
                const li = document.createElement('li');
                li.innerHTML = `
                    <div class="dropdown-item d-flex justify-content-between align-items-center">
                        <a href="#" class="text-decoration-none text-dark flex-grow-1" onclick="applyPreset('${key}'); return false;">
                            ${preset.name} (${preset.width}" × ${preset.height}")
                        </a>
                        <button class="btn btn-link text-danger p-0 ms-2" 
                                onclick="deletePreset('${key}'); return false;">
                            <small>Delete</small>
                        </button>
                    </div>
                `;
                presetsList.appendChild(li);
            });
        }

        // Function to show the add preset modal
        function showAddPresetModal() {
            const modal = new bootstrap.Modal(document.getElementById('addPresetModal'));
            modal.show();
        }

        // Function to save a new preset
        async function saveNewPreset() {
            const name = document.getElementById('presetName').value.trim();
            const width = parseFloat(document.getElementById('presetWidth').value);
            const height = parseFloat(document.getElementById('presetHeight').value);
            const multiplier = parseFloat(document.getElementById('presetMultiplier').value);

            if (!name || !width || !height || !multiplier) {
                alert('Please fill in all fields');
                return;
            }

            try {
                const response = await fetch('/admin/presets', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: name,
                        width: width,
                        height: height,
                        multiplier: multiplier
                    })
                });

                if (response.ok) {
                    const result = await response.json();
                    sizePresets[result.key] = result.preset;
                    updatePresetsDropdown();

                    // Close modal and reset form
                    const modal = bootstrap.Modal.getInstance(document.getElementById('addPresetModal'));
                    modal.hide();
                    document.getElementById('presetForm').reset();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Failed to save preset');
                }
            } catch (error) {
                console.error('Failed to save preset:', error);
                alert('Failed to save preset');
            }
        }

        // Function to delete a preset
        async function deletePreset(key) {
            if (confirm(`Are you sure you want to delete the "${sizePresets[key].name}" preset?`)) {
                try {
                    const response = await fetch(`/admin/presets/${key}`, {
                        method: 'DELETE'
                    });

                    if (response.ok) {
                        delete sizePresets[key];
                        updatePresetsDropdown();
                    } else {
                        const error = await response.json();
                        alert(error.message || 'Failed to delete preset');
                    }
                } catch (error) {
                    console.error('Failed to delete preset:', error);
                    alert('Failed to delete preset');
                }
            }
        }

        function inchesToMm(inches) {
            return (inches * INCH_TO_MM).toFixed(1);
        }

        function updateMetricConversion(sizeEntry) {
            const width = sizeEntry.querySelector('.size-width').value;
            const height = sizeEntry.querySelector('.size-height').value;
            const conversionSpan = sizeEntry.querySelector('.metric-conversion');
            
            if (width && height) {
                const widthMm = inchesToMm(width);
                const heightMm = inchesToMm(height);
                conversionSpan.textContent = `${widthMm} × ${heightMm} mm`;
            } else {
                conversionSpan.textContent = '0 × 0 mm';
            }
        }

        function applyPreset(presetKey) {
            const presetData = sizePresets[presetKey];
            if (!presetData) return;

            const firstSizeEntry = document.querySelector('.size-entry');
            if (!firstSizeEntry) {
                addSizeEntry();
                return;
            }

            const nameInput = firstSizeEntry.querySelector('input[name$="[name]"]');
            const widthInput = firstSizeEntry.querySelector('input[name$="[width]"]');
            const heightInput = firstSizeEntry.querySelector('input[name$="[height]"]');
            const multiplierInput = firstSizeEntry.querySelector('input[name$="[priceMultiplier]"]');

            nameInput.value = presetData.name;
            widthInput.value = presetData.width;
            heightInput.value = presetData.height;
            multiplierInput.value = presetData.multiplier;

            updateNumberUp(firstSizeEntry);
        }

        // Initialize the presets dropdown when the page loads
        document.addEventListener('DOMContentLoaded', function() {
            loadPresets();
        });

        // Add event listeners for size input changes
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('size-width') || e.target.classList.contains('size-height')) {
                updateNumberUp(e.target.closest('.size-entry'));
