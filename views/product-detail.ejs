<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> - SimplePrint</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        .hero-gradient {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .step-indicator {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }
        .step {
            display: flex;
            align-items: center;
            color: #6c757d;
        }
        .step.active {
            color: #0d6efd;
            font-weight: bold;
        }
        .step .step-number {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 0.5rem;
            font-size: 0.9rem;
            font-weight: bold;
        }
        .step.active .step-number {
            background: #0d6efd;
            color: white;
        }
        .step.completed .step-number {
            background: #28a745;
            color: white;
        }
        .option-card {
            border: 2px solid #e9ecef;
            border-radius: 10px;
            padding: 1rem;
            transition: all 0.2s;
            cursor: pointer;
            position: relative;
        }
        .option-card:hover {
            border-color: #0d6efd;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.15);
        }
        .option-card.selected {
            border-color: #0d6efd;
            background: #f8f9ff;
        }
        .option-card .check-mark {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #28a745;
            color: white;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
        }
        .option-card.selected .check-mark {
            display: flex;
        }
        .preview-card {
            width: 100%;
            max-width: 300px;
            aspect-ratio: 3.5/2;
            background: linear-gradient(45deg, #f8f9fa, #e9ecef);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: #6c757d;
            border: 1px solid #dee2e6;
        }
        .price-summary {
            background: linear-gradient(135deg, #28a745, #20c997);
            color: white;
            border-radius: 15px;
            padding: 1.5rem;
        }
        .quantity-selector {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 0.5rem;
        }
        .quantity-btn {
            padding: 0.75rem;
            border: 2px solid #e9ecef;
            background: white;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }
        .quantity-btn:hover {
            border-color: #0d6efd;
        }
        .quantity-btn.selected {
            border-color: #0d6efd;
            background: #f8f9ff;
            font-weight: bold;
        }
        .upload-area {
            border: 2px dashed #ccc;
            border-radius: 10px;
            padding: 2rem;
            text-align: center;
            transition: all 0.2s;
        }
        .upload-area:hover {
            border-color: #0d6efd;
            background: #f8f9ff;
        }
        .upload-area.dragover {
            border-color: #28a745;
            background: #f8fff8;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-printer text-primary"></i> SimplePrint
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/">← Back to Products</a>
                <div class="nav-link">
                    <i class="bi bi-cart3"></i>
                    <span class="badge bg-primary" id="cart-count">0</span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Product Header -->
    <div class="hero-gradient text-white py-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="h2 mb-2"><%= product.name %></h1>
                    <p class="mb-0 opacity-75"><%= product.description %></p>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="d-flex align-items-center justify-content-md-end">
                        <div class="text-warning me-2">★★★★★</div>
                        <small>4.8 (2,341 reviews)</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-4">
        <!-- Step Indicator -->
        <div class="step-indicator">
            <div class="step active" data-step="1">
                <div class="step-number">1</div>
                <span>Choose Options</span>
            </div>
            <div class="step" data-step="2">
                <div class="step-number">2</div>
                <span>Design</span>
            </div>
            <div class="step" data-step="3">
                <div class="step-number">3</div>
                <span>Review & Order</span>
            </div>
        </div>

        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Step 1: Options -->
                <div class="step-content" id="step-1">
                    <!-- Quantity Selection -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-123 text-primary"></i> How many do you need?
                            </h5>
                            <div class="quantity-selector mt-3">
                                <% product.quantityPrices.forEach(qp => { %>
                                    <div class="quantity-btn"
                                         data-quantity="<%= qp.quantity %>"
                                         data-price="<%= qp.price %>"
                                         onclick="selectQuantity(this)">
                                        <div class="fw-bold"><%= qp.quantity %></div>
                                        <div class="text-muted">cards</div>
                                        <div class="text-success">$<%= qp.price %></div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <!-- Size Selection -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-aspect-ratio text-primary"></i> Choose your size
                            </h5>
                            <div class="row mt-3">
                                <% product.sizes.forEach((size, index) => { %>
                                    <div class="col-md-6 col-lg-4 mb-3">
                                        <div class="option-card"
                                             data-size="<%= size.name %>"
                                             data-multiplier="<%= size.priceMultiplier %>"
                                             onclick="selectSize(this)">
                                            <div class="check-mark">
                                                <i class="bi bi-check"></i>
                                            </div>
                                            <h6 class="fw-bold mb-2"><%= size.name %></h6>
                                            <div class="text-muted mb-1"><%= size.width %>" × <%= size.height %>"</div>
                                            <div class="small text-success">
                                                <% if (size.priceMultiplier !== 1) { %>
                                                    <%= size.priceMultiplier %>x price
                                                <% } else { %>
                                                    Standard pricing
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <!-- Paper Selection -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-file-earmark-text text-primary"></i> Select your paper
                            </h5>
                            <div class="row mt-3">
                                <% papers.forEach(paper => { %>
                                    <div class="col-md-6 mb-3">
                                        <div class="option-card"
                                             data-paper="<%= paper.id %>"
                                             data-cost="<%= paper.upgradeCost %>"
                                             onclick="selectPaper(this)">
                                            <div class="check-mark">
                                                <i class="bi bi-check"></i>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="fw-bold mb-0"><%= paper.name %></h6>
                                                <span class="badge <%= paper.category === 'premium' ? 'bg-warning' : 'bg-secondary' %>">
                                                    <%= paper.category %>
                                                </span>
                                            </div>
                                            <div class="text-muted mb-2">
                                                <%= paper.thickness %> • <%= paper.finish %>
                                            </div>
                                            <div class="small text-muted mb-2"><%= paper.description %></div>
                                            <div class="text-success fw-semibold">
                                                <% if (paper.upgradeCost > 0) { %>
                                                    +$<%= paper.upgradeCost %>
                                                <% } else { %>
                                                    Included
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <!-- Upgrades -->
                    <% if (product.upgrades && product.upgrades.length > 0) { %>
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="bi bi-plus-circle text-primary"></i> Add upgrades
                                </h5>
                                <div class="mt-3">
                                    <% product.upgrades.forEach(upgrade => { %>
                                        <div class="form-check mb-3 p-3 border rounded">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   id="upgrade-<%= upgrade.name.replace(/\s+/g, '-') %>"
                                                   data-cost="<%= upgrade.upgradeCost %>"
                                                   onchange="updateUpgrades()">
                                            <label class="form-check-label w-100" for="upgrade-<%= upgrade.name.replace(/\s+/g, '-') %>">
                                                <div class="d-flex justify-content-between">
                                                    <div>
                                                        <h6 class="fw-bold mb-1"><%= upgrade.name %></h6>
                                                        <p class="text-muted mb-0 small"><%= upgrade.description %></p>
                                                    </div>
                                                    <div class="text-success fw-bold">+$<%= upgrade.upgradeCost %></div>
                                                </div>
                                            </label>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        </div>
                    <% } %>

                    <!-- Continue Button -->
                    <div class="d-flex justify-content-end">
                        <button class="btn btn-primary btn-lg" onclick="goToStep(2)">
                            Continue to Design
                            <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>

                <!-- Step 2: Design -->
                <div class="step-content d-none" id="step-2">
                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-palette text-primary"></i> Add your design
                            </h5>

                            <!-- Upload Area -->
                            <div class="upload-area mt-3" id="upload-area">
                                <i class="bi bi-cloud-upload display-4 text-muted mb-3"></i>
                                <h5>Drag & drop your design here</h5>
                                <p class="text-muted">or click to browse files</p>
                                <input type="file" id="design-upload" class="d-none" accept="image/*,.pdf" multiple>
                                <div class="mt-3">
                                    <small class="text-muted">
                                        Accepted formats: PDF, PNG, JPG • Maximum file size: 25MB
                                    </small>
                                </div>
                            </div>

                            <!-- Template Options -->
                            <div class="mt-4">
                                <h6 class="mb-3">Or choose from our templates</h6>
                                <div class="row">
                                    <% for(let i = 1; i <= 6; i++) { %>
                                        <div class="col-md-4 col-lg-3 mb-3">
                                            <div class="card template-card h-100" onclick="selectTemplate('<%= i %>')">
                                                <div class="card-body text-center">
                                                    <i class="bi bi-file-earmark-text display-4 text-primary mb-2"></i>
                                                    <h6 class="card-title">Template <%= i %></h6>
                                                    <small class="text-muted">Professional design</small>
                                                </div>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Design Tools -->
                            <div class="mt-4">
                                <h6 class="mb-3">Design tools</h6>
                                <div class="btn-group" role="group">
                                    <button type="button" class="btn btn-outline-primary">
                                        <i class="bi bi-type"></i> Add Text
                                    </button>
                                    <button type="button" class="btn btn-outline-primary">
                                        <i class="bi bi-image"></i> Add Logo
                                    </button>
                                    <button type="button" class="btn btn-outline-primary">
                                        <i class="bi bi-palette"></i> Colors
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Navigation -->
                    <div class="d-flex justify-content-between">
                        <button class="btn btn-outline-secondary" onclick="goToStep(1)">
                            <i class="bi bi-arrow-left me-2"></i>
                            Back to Options
                        </button>
                        <button class="btn btn-primary btn-lg" onclick="goToStep(3)">
                            Continue to Review
                            <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>

                <!-- Step 3: Review -->
                <div class="step-content d-none" id="step-3">
                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-clipboard-check text-primary"></i> Review your order
                            </h5>

                            <div id="order-summary" class="mt-3">
                                <!-- Order summary will be populated by JavaScript -->
                            </div>

                            <!-- Shipping Info -->
                            <div class="mt-4">
                                <h6>Shipping Information</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Full Name</label>
                                            <input type="text" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Email</label>
                                            <input type="email" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="mb-3">
                                            <label class="form-label">Address</label>
                                            <input type="text" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label class="form-label">City</label>
                                            <input type="text" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label class="form-label">State</label>
                                            <select class="form-select" required>
                                                <option value="">Select State</option>
                                                <option value="CA">California</option>
                                                <option value="NY">New York</option>
                                                <option value="TX">Texas</option>
                                                <!-- Add more states -->
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label class="form-label">ZIP Code</label>
                                            <input type="text" class="form-control" required>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Navigation -->
                    <div class="d-flex justify-content-between">
                        <button class="btn btn-outline-secondary" onclick="goToStep(2)">
                            <i class="bi bi-arrow-left me-2"></i>
                            Back to Design
                        </button>
                        <button class="btn btn-success btn-lg" onclick="placeOrder()">
                            <i class="bi bi-credit-card me-2"></i>
                            Place Order
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 100px;">
                    <!-- Preview -->
                    <div class="card mb-4">
                        <div class="card-body text-center">
                            <h6 class="card-title">Preview</h6>
                            <div class="preview-card mx-auto mb-3">
                                <i class="bi bi-credit-card-2-front"></i>
                            </div>
                            <div class="d-flex justify-content-center gap-2">
                                <button class="btn btn-outline-primary btn-sm">Front</button>
                                <button class="btn btn-outline-secondary btn-sm">Back</button>
                            </div>
                        </div>
                    </div>

                    <!-- Price Summary -->
                    <div class="price-summary">
                        <h6 class="mb-3">Order Summary</h6>
                        <div id="price-breakdown">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Select quantity first</span>
                                <span>--</span>
                            </div>
                        </div>
                        <hr class="my-3 opacity-50">
                        <div class="d-flex justify-content-between">
                            <h5 class="mb-0">Total:</h5>
                            <h5 class="mb-0" id="total-price">$0.00</h5>
                        </div>
                        <div class="text-center mt-3">
                            <small class="opacity-75">
                                <i class="bi bi-truck"></i>
                                Free shipping on orders over $50
                            </small>
                        </div>
                    </div>

                    <!-- Guarantees -->
                    <div class="card mt-4">
                        <div class="card-body">
                            <h6 class="card-title">Our Guarantee</h6>
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-shield-check text-success me-2"></i>
                                <small>100% Satisfaction Guarantee</small>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-lightning-charge text-warning me-2"></i>
                                <small>Fast 3-5 day delivery</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-award text-primary me-2"></i>
                                <small>Premium quality materials</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Product data
        const product = <%- JSON.stringify(product) %>;
        const papers = <%- JSON.stringify(papers) %>;

        // Order state
        let orderState = {
            quantity: null,
            basePrice: 0,
            size: null,
            sizeMultiplier: 1,
            paper: null,
            paperCost: 0,
            upgrades: [],
            upgradesCost: 0,
            design: null
        };

        // Step navigation
        function goToStep(stepNumber) {
            // Hide all steps
            document.querySelectorAll('.step-content').forEach(content => {
                content.classList.add('d-none');
            });

            // Show target step
            document.getElementById(`step-${stepNumber}`).classList.remove('d-none');

            // Update step indicators
            document.querySelectorAll('.step').forEach((step, index) => {
                step.classList.remove('active', 'completed');
                if (index + 1 === stepNumber) {
                    step.classList.add('active');
                } else if (index + 1 < stepNumber) {
                    step.classList.add('completed');
                }
            });

            // Update order summary if on review step
            if (stepNumber === 3) {
                updateOrderSummary();
            }
        }

        // Quantity selection
        function selectQuantity(element) {
            document.querySelectorAll('.quantity-btn').forEach(btn => btn.classList.remove('selected'));
            element.classList.add('selected');

            orderState.quantity = parseInt(element.dataset.quantity);
            orderState.basePrice = parseFloat(element.dataset.price);

            updatePricing();
        }

        // Size selection
        function selectSize(element) {
            document.querySelectorAll('[data-size]').forEach(card => card.classList.remove('selected'));
            element.classList.add('selected');

            orderState.size = element.dataset.size;
            orderState.sizeMultiplier = parseFloat(element.dataset.multiplier);

            updatePricing();
        }

        // Paper selection
        function selectPaper(element) {
            document.querySelectorAll('[data-paper]').forEach(card => card.classList.remove('selected'));
            element.classList.add('selected');

            orderState.paper = element.dataset.paper;
            orderState.paperCost = parseFloat(element.dataset.cost);

            updatePricing();
        }

        // Upgrades
        function updateUpgrades() {
            orderState.upgrades = [];
            orderState.upgradesCost = 0;

            document.querySelectorAll('input[type="checkbox"]:checked').forEach(checkbox => {
                const cost = parseFloat(checkbox.dataset.cost);
                orderState.upgrades.push({
                    name: checkbox.id,
                    cost: cost
                });
                orderState.upgradesCost += cost;
            });

            updatePricing();
        }

        // Update pricing display
        function updatePricing() {
            if (!orderState.quantity || !orderState.basePrice) {
                document.getElementById('price-breakdown').innerHTML = `
                    <div class="d-flex justify-content-between mb-2">
                        <span>Select quantity first</span>
                        <span>--</span>
                    </div>
                `;
                document.getElementById('total-price').textContent = '$0.00';
                return;
            }

            const subtotal = orderState.basePrice * orderState.sizeMultiplier;
            const total = subtotal + orderState.paperCost + orderState.upgradesCost;

            let breakdown = `
                <div class="d-flex justify-content-between mb-2">
                    <span>${orderState.quantity} cards</span>
                    <span>$${orderState.basePrice.toFixed(2)}</span>
                </div>
            `;

            if (orderState.sizeMultiplier !== 1) {
                breakdown += `
                    <div class="d-flex justify-content-between mb-2">
                        <span>Size adjustment (${orderState.sizeMultiplier}x)</span>
                        <span>$${(subtotal - orderState.basePrice).toFixed(2)}</span>
                    </div>
                `;
            }

            if (orderState.paperCost > 0) {
                breakdown += `
                    <div class="d-flex justify-content-between mb-2">
                        <span>Paper upgrade</span>
                        <span>$${orderState.paperCost.toFixed(2)}</span>
                    </div>
                `;
            }

            if (orderState.upgradesCost > 0) {
                breakdown += `
                    <div class="d-flex justify-content-between mb-2">
                        <span>Upgrades</span>
                        <span>$${orderState.upgradesCost.toFixed(2)}</span>
                    </div>
                `;
            }

            document.getElementById('price-breakdown').innerHTML = breakdown;
            document.getElementById('total-price').textContent = `$${total.toFixed(2)}`;
        }

        // Template selection
        function selectTemplate(templateId) {
            orderState.design = `template-${templateId}`;
            // Show visual feedback
            document.querySelectorAll('.template-card').forEach(card => card.classList.remove('border-primary'));
            event.target.closest('.template-card').classList.add('border-primary');
        }

        // File upload handling
        document.getElementById('upload-area').addEventListener('click', () => {
            document.getElementById('design-upload').click();
        });

        document.getElementById('design-upload').addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                orderState.design = 'custom-upload';
                document.getElementById('upload-area').innerHTML = `
                    <i class="bi bi-check-circle display-4 text-success mb-3"></i>
                    <h5 class="text-success">${e.target.files.length} file(s) uploaded</h5>
                    <p class="text-muted">Click to change files</p>
                `;
            }
        });

        // Order summary
        function updateOrderSummary() {
            const summary = document.getElementById('order-summary');

            if (!orderState.quantity) {
                summary.innerHTML = '<p class="text-muted">Please complete your selections first.</p>';
                return;
            }

            summary.innerHTML = `
                <div class="row">
                    <div class="col-md-6">
                        <h6>Product Details</h6>
                        <p><strong>${product.name}</strong></p>
                        <ul class="list-unstyled">
                            <li>Quantity: ${orderState.quantity} cards</li>
                            <li>Size: ${orderState.size || 'Not selected'}</li>
                            <li>Paper: ${orderState.paper ? papers.find(p => p.id === orderState.paper)?.name : 'Not selected'}</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6>Design</h6>
                        <p>${orderState.design ? 'Design uploaded' : 'No design uploaded'}</p>

                        <h6 class="mt-3">Delivery</h6>
                        <p>Standard delivery (3-5 business days)</p>
                    </div>
                </div>
            `;
        }

        // Place order
        function placeOrder() {
            alert(`Order placed! Total: $${document.getElementById('total-price').textContent.slice(1)}\n\nThis would integrate with your payment processor.`);
        }

        // Initialize default selections
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-select first quantity if only one option
            const quantityBtns = document.querySelectorAll('.quantity-btn');
            if (quantityBtns.length === 1) {
                selectQuantity(quantityBtns[0]);
            }

            // Auto-select first size if only one option
            const sizeCards = document.querySelectorAll('[data-size]');
            if (sizeCards.length === 1) {
                selectSize(sizeCards[0]);
            }

            // Auto-select first paper if only one option
            const paperCards = document.querySelectorAll('[data-paper]');
            if (paperCards.length === 1) {
                selectPaper(paperCards[0]);
            }
        });
    </script>
</body>
</html>