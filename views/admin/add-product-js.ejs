function addQuantityPrice() {
    const tbody = document.querySelector('#quantityPricesContainer tbody');
    const template = `
        <tr>
            <td>
                <input type="number" class="form-control quantity-input" 
                       name="quantityPrices[${quantityPriceCount}][quantity]" 
                       required
                       onchange="updatePricePerCard(this)">
            </td>
            <td>
                <input type="number" class="form-control price-input" 
                       name="quantityPrices[${quantityPriceCount}][price]" 
                       step="0.01" required
                       onchange="updatePricePerCard(this)">
            </td>
            <td>
                <span class="price-per-card">$0.00</span>
            </td>
            <td>
                <button type="button" class="btn btn-danger btn-sm" onclick="removeQuantityPrice(this)">
                    Remove
                </button>
            </td>
        </tr>
    `;
    tbody.insertAdjacentHTML('beforeend', template);
    quantityPriceCount++;
    sortQuantityPrices();
}

function removeQuantityPrice(button) {
    const row = button.closest('tr');
    row.remove();
    updateQuantityPriceIndexes();
}

function updatePricePerCard(input) {
    const row = input.closest('tr');
    const quantity = parseFloat(row.querySelector('.quantity-input').value) || 0;
    const price = parseFloat(row.querySelector('.price-input').value) || 0;
    const pricePerCard = quantity > 0 ? (price / quantity).toFixed(3) : '0.00';
    row.querySelector('.price-per-card').textContent = `$${pricePerCard}`;
    sortQuantityPrices();
}

function sortQuantityPrices() {
    const tbody = document.querySelector('#quantityPricesContainer tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    
    rows.sort((a, b) => {
        const quantityA = parseInt(a.querySelector('.quantity-input').value) || 0;
        const quantityB = parseInt(b.querySelector('.quantity-input').value) || 0;
        return quantityA - quantityB;
    });

    rows.forEach(row => tbody.appendChild(row));
    updateQuantityPriceIndexes();
}

function updateQuantityPriceIndexes() {
    const rows = document.querySelectorAll('#quantityPricesContainer tbody tr');
    rows.forEach((row, index) => {
        row.querySelector('.quantity-input').name = `quantityPrices[${index}][quantity]`;
        row.querySelector('.price-input').name = `quantityPrices[${index}][price]`;
    });
    quantityPriceCount = rows.length;
}

// Price calculator functions
let currentProduct = null;

function openPriceCalculator() {
    try {
        // Get current form data
        const form = document.getElementById('editProductForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        // Build product object
        currentProduct = {
            id: data.id || 'temp',
            name: data.name,
            sizes: [],
            selectedPaperIds: document.getElementById('selectedPaperIds').value.split(','),
            upgrades: [],
            quantityPrices: []
        };
        const product = currentProduct;

        // Collect sizes
        document.querySelectorAll('.size-entry').forEach((entry, index) => {
            product.sizes.push({
                name: entry.querySelector('input[name^="sizes"][name$="[name]"]').value,
                width: parseFloat(entry.querySelector('input[name$="[width]"]').value),
                height: parseFloat(entry.querySelector('input[name$="[height]"]').value),
                priceMultiplier: parseFloat(entry.querySelector('input[name$="[priceMultiplier]"]').value)
            });
        });

        // Collect upgrades
        document.querySelectorAll('.upgrade-entry').forEach((entry, index) => {
            product.upgrades.push({
                name: entry.querySelector('input[name^="upgrades"][name$="[name]"]').value,
                upgradeCost: parseFloat(entry.querySelector('input[name$="[upgradeCost]"]').value),
                description: entry.querySelector('textarea[name$="[description]"]').value
            });
        });

        // Collect quantity prices
        document.querySelectorAll('#quantityPricesContainer tbody tr').forEach((row, index) => {
            product.quantityPrices.push({
                quantity: parseInt(row.querySelector('.quantity-input').value),
                price: parseFloat(row.querySelector('.price-input').value)
            });
        });

        // Initialize calculator modal
        const modal = new bootstrap.Modal(document.getElementById('priceCalculatorModal'));
        
        // Set product name
        document.getElementById('productName').value = product.name;

        // Populate quantity options
        const quantitySelect = document.getElementById('quantitySelect');
        quantitySelect.innerHTML = product.quantityPrices.map(qp => 
            `<option value="${qp.quantity}" data-price="${qp.price}">${qp.quantity} cards - $${qp.price}</option>`
        ).join('');

        // Populate size options
        const sizeSelect = document.getElementById('sizeSelect');
        sizeSelect.innerHTML = product.sizes.map(size => 
            `<option value="${size.name}" data-multiplier="${size.priceMultiplier}">
                ${size.name} (${size.width}" × ${size.height}")
            </option>`
        ).join('');

        // Populate paper options - only show papers selected for this product
        const paperSelect = document.getElementById('paperSelect');

        // Filter papers based on product's selectedPaperIds
        let availablePapers = papers;
        if (product.selectedPaperIds && product.selectedPaperIds.length > 0) {
            availablePapers = papers.filter(paper => product.selectedPaperIds.includes(paper.id));
        }

        const standardPapers = availablePapers.filter(p => p.category === 'standard');
        const premiumPapers = availablePapers.filter(p => p.category === 'premium');

        let paperOptions = '';

        if (standardPapers.length > 0) {
            paperOptions += `
                <optgroup label="Standard Papers">
                    ${standardPapers.map(paper => `
                        <option value="${paper.id}"
                                data-cost="${paper.upgradeCost}"
                                title="${paper.description}">
                            ${paper.name} - ${paper.thickness} ${paper.finish}
                        </option>
                    `).join('')}
                </optgroup>
            `;
        }

        if (premiumPapers.length > 0) {
            paperOptions += `
                <optgroup label="Premium Papers">
                    ${premiumPapers.map(paper => `
                        <option value="${paper.id}"
                                data-cost="${paper.upgradeCost}"
                                title="${paper.description}">
                            ${paper.name} - ${paper.thickness} ${paper.finish} (+$${paper.upgradeCost})
                        </option>
                    `).join('')}
                </optgroup>
            `;
        }

        paperSelect.innerHTML = paperOptions;

        // Populate color options
        const colorOptions = ['Color', 'Black', 'No Print'];
        const frontColorSelect = document.getElementById('frontColorSelect');
        const backColorSelect = document.getElementById('backColorSelect');

        frontColorSelect.innerHTML = colorOptions.map(color =>
            `<option value="${color}">${color}</option>`
        ).join('');

        backColorSelect.innerHTML = colorOptions.map(color =>
            `<option value="${color}">${color}</option>`
        ).join('');

        // Populate upgrades
        const upgradesContainer = document.getElementById('upgradesContainer');
        upgradesContainer.innerHTML = product.upgrades.map(upgrade => `
            <div class="form-check">
                <input class="form-check-input" type="checkbox" 
                       id="upgrade_${upgrade.name}" 
                       data-cost="${upgrade.upgradeCost}"
                       onchange="calculatePrice()">
                <label class="form-check-label">
                    ${upgrade.name} (+$${upgrade.upgradeCost})
                    <small class="text-muted d-block">${upgrade.description}</small>
                </label>
            </div>
        `).join('');

        calculatePrice();
        modal.show();
    } catch (error) {
        console.error('Error opening calculator:', error);
        showNotification('Error', 'Failed to open calculator: ' + error.message, 'danger');
    }
}

async function calculatePrice() {
    try {
        // Get form values
        const quantitySelect = document.getElementById('quantitySelect');
        const quantity = parseInt(quantitySelect.value);
        const paperId = document.getElementById('paperSelect').value;
        const size = document.getElementById('sizeSelect').value;
        const colorFront = document.getElementById('frontColorSelect').value;
        const colorBack = document.getElementById('backColorSelect').value;

        // Get selected upgrades
        const upgradeNames = Array.from(document.querySelectorAll('#upgradesContainer input[type="checkbox"]:checked'))
            .map(checkbox => checkbox.id.replace('upgrade_', ''));

        if (!quantity || !paperId || !size || !colorFront || !colorBack) {
            document.getElementById('priceBreakdown').innerHTML = '<div class="alert alert-warning">Please fill all required fields</div>';
            return;
        }

        // Show loading
        document.getElementById('priceBreakdown').innerHTML = '<div class="spinner-border spinner-border-sm" role="status"></div> Calculating...';

        // Call API
        const response = await fetch('/api/v1/calculate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                productId: currentProduct.id,
                quantity,
                size,
                paperId,
                colorFront,
                colorBack,
                upgradeNames
            })
        });

        if (!response.ok) {
            const error = await response.json();
            throw new Error(error.message || 'Calculation failed');
        }

        const result = await response.json();
        const data = result.data;

        // Display calculation details
        let html = '';

        if (data.calculation) {
            html += `<div class="mb-2"><strong>Calculation Details:</strong></div>`;
            html += `<div class="mb-2">Number Up: ${data.calculation.numberUp} per sheet</div>`;
            html += `<div class="mb-2">Sheets Needed: ${data.calculation.sheetsNeeded}</div>`;
            html += `<div class="mb-2">Paper Cost: $${data.calculation.paperCostTotal.toFixed(2)} (${data.calculation.sheetsNeeded} × $${data.calculation.paperCostPerSheet.toFixed(2)})</div>`;
            html += `<div class="mb-2">Click Cost: $${data.calculation.clickCostTotal.toFixed(2)} (${data.calculation.sheetsNeeded} × $${data.calculation.clickCostPerSheet.toFixed(2)})</div>`;
        }

        if (data.totals) {
            html += `<hr>`;
            html += `<div class="mb-2">Base Price: $${data.totals.basePrice.toFixed(2)}</div>`;
            if (data.totals.sizeAdjustment > 0) {
                html += `<div class="mb-2">Size Adjustment (${data.totals.sizeMultiplier}x): +$${data.totals.sizeAdjustment.toFixed(2)}</div>`;
            }
            if (data.totals.paperUpgrade > 0) {
                html += `<div class="mb-2">Paper Upgrade: +$${data.totals.paperUpgrade.toFixed(2)}</div>`;
            }
            if (data.totals.upgradesCost > 0) {
                html += `<div class="mb-2">Upgrades: +$${data.totals.upgradesCost.toFixed(2)}</div>`;
            }
            html += `<div class="total mt-3"><strong>Grand Total: $${data.totals.grandTotal.toFixed(2)}</strong></div>`;
            html += `<div class="mt-1">Unit Price: $${data.totals.unitPrice.toFixed(3)}</div>`;
        }

        document.getElementById('priceBreakdown').innerHTML = html;

    } catch (error) {
        console.error('Error calculating price:', error);
        document.getElementById('priceBreakdown').innerHTML = `
            <div class="alert alert-danger">
                Error: ${error.message}
            </div>
        `;
    }
}

// Auto-calculate all quantity prices
async function autoCalculateAllPrices() {
    try {
        // Get settings (markup percentage)
        const settingsResponse = await fetch('/admin/settings');
        const settingsData = await settingsResponse.json();
        const markupPercentage = settingsData.data?.markup?.percentage || 50;

        // Get click costs
        const clickCosts = {
            color: parseFloat(document.querySelector('input[name="clickCosts[color]"]').value) || 0.10,
            black: parseFloat(document.querySelector('input[name="clickCosts[black]"]').value) || 0.05
        };

        // Get selected papers
        const selectedPaperIdsInput = document.getElementById('selectedPaperIds').value;
        if (!selectedPaperIdsInput) {
            alert('Please select at least one paper type first');
            return;
        }
        const selectedPaperIds = selectedPaperIdsInput.split(',').map(id => id.trim());

        // Get first paper
        const firstPaper = papers.find(p => selectedPaperIds.includes(p.id));
        if (!firstPaper) {
            alert('No valid paper selected');
            return;
        }

        // Get first size
        const firstSizeEntry = document.querySelector('.size-entry');
        if (!firstSizeEntry) {
            alert('Please add at least one size first');
            return;
        }

        const width = parseFloat(firstSizeEntry.querySelector('input[name$="[width]"]').value);
        const height = parseFloat(firstSizeEntry.querySelector('input[name$="[height]"]').value);
        const priceMultiplier = parseFloat(firstSizeEntry.querySelector('input[name$="[priceMultiplier]"]').value);

        if (!width || !height || !priceMultiplier) {
            alert('Please fill in size details first');
            return;
        }

        // Calculate number up
        const bleed = 0.125;
        const jobWidth = width + (bleed * 2);
        const jobHeight = height + (bleed * 2);
        const acrossSheet = Math.floor(firstPaper.parentSheetSize.width / jobWidth);
        const downSheet = Math.floor(firstPaper.parentSheetSize.height / jobHeight);
        const numberUp = acrossSheet * downSheet;

        if (numberUp === 0) {
            alert('Job size is too large for the parent sheet');
            return;
        }

        // Loop through all quantity rows and calculate prices
        const rows = document.querySelectorAll('#quantityPricesContainer tbody tr');
        rows.forEach(row => {
            const quantityInput = row.querySelector('.quantity-input');
            const priceInput = row.querySelector('.price-input');

            if (!quantityInput || !priceInput) return;

            const quantity = parseInt(quantityInput.value);
            if (!quantity || quantity <= 0) return;

            // Calculate sheets needed
            const sheetsNeeded = Math.ceil(quantity / numberUp);

            // Calculate paper cost
            const paperCost = sheetsNeeded * firstPaper.costPerSheet;

            // Calculate click cost (assume Color front and back as default)
            const clickCostPerSheet = clickCosts.color * 2; // front + back
            const clickCost = sheetsNeeded * clickCostPerSheet;

            // Base cost
            let calcCost = paperCost + clickCost;

            // Apply size multiplier
            calcCost = calcCost * priceMultiplier;

            // Apply markup
            const markupMultiplier = 1 + (markupPercentage / 100);
            let finalPrice = calcCost * markupMultiplier;

            // Round up to nearest cent
            finalPrice = Math.ceil(finalPrice * 100) / 100;

            // Update price input
            priceInput.value = finalPrice.toFixed(2);

            // Update price per card display
            updatePricePerCard(priceInput);
        });

        showNotification('Success', 'Prices calculated successfully! You can still manually adjust any price.', 'success');

    } catch (error) {
        console.error('Error auto-calculating prices:', error);
        showNotification('Error', 'Failed to calculate prices: ' + error.message, 'danger');
    }
}

// Initialize number up calculations on page load (for edit-product page)
document.addEventListener('DOMContentLoaded', function() {
    // Wait a bit for selectedPapers to be populated
    setTimeout(() => {
        if (selectedPapers.size > 0) {
            updateAllNumberUp();
        }

        // Also calculate quantity pricing rows on page load
        document.querySelectorAll('.quantity-input').forEach(input => {
            if (input.value) {
                autoCalculateRowPrice(input);
            }
        });
    }, 100);
});
