        function removeUpgrade(button) {
            const entry = button.closest('.upgrade-entry');
            entry.remove();
            updateUpgradeIndexes();
        }

        function updateUpgradeIndexes() {
            const entries = document.querySelectorAll('#upgradesContainer .upgrade-entry');
            entries.forEach((entry, index) => {
                entry.querySelector('input[name*="[name]"]').name = `upgrades[${index}][name]`;
                entry.querySelector('input[name*="[upgradeCost]"]').name = `upgrades[${index}][upgradeCost]`;
                entry.querySelector('textarea[name*="[description]"]').name = `upgrades[${index}][description]`;
            });
            upgradeCount = entries.length;
        }
        async function autoCalculateRowPrice(input) {
            const row = input.closest('tr');
            const quantity = parseInt(input.value);

            if (!quantity || quantity <= 0) {
                row.querySelector('.sheets-display').textContent = '-';
                row.querySelector('.paper-cost-display').textContent = '-';
                row.querySelector('.click-cost-display').textContent = '-';
                row.querySelector('.total-cost-display').textContent = '-';
                row.querySelector('.markup-display').textContent = '-';
                return;
            }

            // Get first size
            const firstSizeEntry = document.querySelector('.size-entry');
            if (!firstSizeEntry) {
                row.querySelector('.sheets-display').textContent = 'No size';
                return;
            }

            const width = parseFloat(firstSizeEntry.querySelector('.size-width').value);
            const height = parseFloat(firstSizeEntry.querySelector('.size-height').value);
            const priceMultiplier = parseFloat(firstSizeEntry.querySelector('input[name$="[priceMultiplier]"]').value) || 1;

            if (!width || !height) {
                row.querySelector('.sheets-display').textContent = 'Enter size';
                return;
            }

            // Check if paper is selected
            if (selectedPapers.size === 0) {
                row.querySelector('.sheets-display').textContent = 'No paper';
                return;
            }

            // Get first selected paper
            const firstPaper = Array.from(selectedPapers.values())[0];

            // Get click costs
            const clickCosts = {
                color: parseFloat(document.querySelector('input[name="clickCosts[color]"]').value) || 0.10,
                black: parseFloat(document.querySelector('input[name="clickCosts[black]"]').value) || 0.05
            };

            // Calculate number up
            const bleed = 0.125;
            const jobWidth = width + (bleed * 2);
            const jobHeight = height + (bleed * 2);
            const acrossSheet = Math.floor(firstPaper.parentSheetSize.width / jobWidth);
            const downSheet = Math.floor(firstPaper.parentSheetSize.height / jobHeight);
            const numberUp = acrossSheet * downSheet;

            if (numberUp === 0) {
                row.querySelector('.sheets-display').textContent = '0 (too large)';
                row.querySelector('.paper-cost-display').textContent = '-';
                row.querySelector('.click-cost-display').textContent = '-';
                row.querySelector('.total-cost-display').textContent = '-';
                row.querySelector('.markup-display').textContent = '-';
                return;
            }

            // Calculate costs
            const sheetsNeeded = Math.ceil(quantity / numberUp);
            const paperCost = sheetsNeeded * firstPaper.costPerSheet;
            const clickCostPerSheet = clickCosts.color * 2; // front + back
            const clickCost = sheetsNeeded * clickCostPerSheet;
            const totalCost = (paperCost + clickCost) * priceMultiplier;

            // Get markup percentage from settings
            let markupPercentage = 50; // default fallback
            try {
                const settingsResponse = await fetch('/admin/settings');
                if (settingsResponse.ok) {
                    const settingsData = await settingsResponse.json();
                    markupPercentage = settingsData.data?.markup?.percentage || 50;
                }
            } catch (error) {
                console.warn('Could not fetch markup settings, using default 50%');
            }

            // Display results
            row.querySelector('.sheets-display').textContent = sheetsNeeded;
            row.querySelector('.paper-cost-display').textContent = '$' + paperCost.toFixed(2);
            row.querySelector('.click-cost-display').textContent = '$' + clickCost.toFixed(2);
            row.querySelector('.total-cost-display').textContent = '$' + totalCost.toFixed(2);
            row.querySelector('.markup-display').textContent = markupPercentage + '%';

            // Auto-fill price with calculated value
            const priceInput = row.querySelector('.price-input');
            const markupMultiplier = 1 + (markupPercentage / 100);
            const suggestedPrice = Math.ceil(totalCost * markupMultiplier * 100) / 100;
            priceInput.value = suggestedPrice.toFixed(2);

            updatePricePerCard(priceInput);
        }

        function addQuantityPrice() {
            const tbody = document.querySelector('#quantityPricesContainer tbody');
            const template = `
                <tr>
                    <td>
                        <input type="number" class="form-control form-control-sm quantity-input"
                               name="quantityPrices[${quantityPriceCount}][quantity]"
                               required
                               oninput="autoCalculateRowPrice(this)">
                    </td>
                    <td class="sheets-display">-</td>
                    <td class="paper-cost-display">-</td>
                    <td class="click-cost-display">-</td>
                    <td class="total-cost-display">-</td>
                    <td class="markup-display">-</td>
                    <td>
                        <input type="number" class="form-control form-control-sm price-input"
                               name="quantityPrices[${quantityPriceCount}][price]"
                               step="0.01" required
                               onchange="updatePricePerCard(this)">
                    </td>
                    <td>
                        <span class="price-per-card">$0.00</span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-danger btn-sm" onclick="removeQuantityPrice(this)">
                            Remove
                        </button>
                    </td>
                </tr>
            `;
            tbody.insertAdjacentHTML('beforeend', template);
            quantityPriceCount++;
            sortQuantityPrices();
        }

        function removeQuantityPrice(button) {
            const row = button.closest('tr');
            row.remove();
            updateQuantityPriceIndexes();
        }

        function updatePricePerCard(input) {
            const row = input.closest('tr');
            const quantity = parseFloat(row.querySelector('.quantity-input').value) || 0;
            const price = parseFloat(row.querySelector('.price-input').value) || 0;
            const pricePerCard = quantity > 0 ? (price / quantity).toFixed(3) : '0.00';
            row.querySelector('.price-per-card').textContent = `$${pricePerCard}`;
            sortQuantityPrices();
        }

        function sortQuantityPrices() {
            const tbody = document.querySelector('#quantityPricesContainer tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            
            rows.sort((a, b) => {
                const quantityA = parseInt(a.querySelector('.quantity-input').value) || 0;
                const quantityB = parseInt(b.querySelector('.quantity-input').value) || 0;
                return quantityA - quantityB;
            });

            rows.forEach(row => tbody.appendChild(row));
            updateQuantityPriceIndexes();
        }

        function updateQuantityPriceIndexes() {
            const rows = document.querySelectorAll('#quantityPricesContainer tbody tr');
            rows.forEach((row, index) => {
                row.querySelector('.quantity-input').name = `quantityPrices[${index}][quantity]`;
                row.querySelector('.price-input').name = `quantityPrices[${index}][price]`;
            });
            quantityPriceCount = rows.length;
        }

        // Let the form submit normally to the server

        // Initialize price per card calculations on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Wait a bit for selectedPapers to be populated
            setTimeout(() => {
                document.querySelectorAll('.quantity-input').forEach(input => {
                    if (input.value) {
                        autoCalculateRowPrice(input);
                    }
                    updatePricePerCard(input);
                });
            }, 100);

            // Add form submission handler for debugging
            const form = document.getElementById('addProductForm');
            const button = document.getElementById('createProductBtn');

            console.log('=== FORM ELEMENT:', form);
            console.log('=== BUTTON ELEMENT:', button);

            if (form) {
                form.addEventListener('submit', function(e) {
                    console.log('=== FORM SUBMIT EVENT TRIGGERED ===');

                    // Check form validity
                    if (!form.checkValidity()) {
                        console.log('=== FORM VALIDATION FAILED ===');
                        e.preventDefault();
                        form.reportValidity();
                        return false;
                    }

                    console.log('=== FORM IS VALID, SUBMITTING... ===');
                    // Let form submit normally
                });
            }

            if (button) {
                button.addEventListener('click', function(e) {
                    console.log('=== BUTTON CLICK EVENT TRIGGERED ===');
                    console.log('Button type:', this.type);
                    console.log('Form:', this.form);
                    console.log('Button parent:', this.parentElement);
                    console.log('Is button inside form?', form.contains(this));

                    // Always prevent default and use FormData approach
                    e.preventDefault();
                    console.log('=== USING FORMDATA APPROACH ===');

                    if (form.checkValidity()) {
                        console.log('=== FORM IS VALID, CREATING FORMDATA ===');

                        const formData = new FormData(form);

                        // Log form data for debugging
                        console.log('=== FORM DATA ENTRIES ===');
                        for (let [key, value] of formData.entries()) {
                            console.log(key, ':', value);
                        }

                        // Submit using fetch
                        fetch('/admin/products', {
                            method: 'POST',
                            body: formData
                        })
                        .then(response => {
                            console.log('=== RESPONSE STATUS:', response.status);
                            if (response.ok) {
                                console.log('=== SUCCESS - REDIRECTING ===');
                                window.location.href = '/admin/dashboard';
                            } else {
                                return response.json().then(err => {
                                    throw new Error(err.message || 'Failed to create product');
                                });
                            }
                        })
                        .catch(error => {
                            console.error('=== SUBMISSION ERROR:', error);
                            alert('Failed to create product: ' + error.message);
                        });

                    } else {
                        console.log('=== FORM VALIDATION FAILED ===');
                        form.reportValidity();
                    }
                });
            }
        });
    </script>
