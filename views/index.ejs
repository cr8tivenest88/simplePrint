<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Custom Business Cards</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
    <!-- Hero Section -->
    <div class="bg-primary text-white py-5 text-center">
        <div class="container">
            <h1 class="display-4">Professional Business Cards</h1>
            <p class="lead">Try 50 cards for $13</p>
            <button class="btn btn-success btn-lg">Get Free Sample Kit</button>
        </div>
    </div>

    <div class="container my-5">
        <div class="row">
            <!-- Options Column -->
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Customize Your Cards</h5>
                        
                        <!-- Paper Selection -->
                        <div class="mb-3">
                            <label for="paper-select" class="form-label">Select Paper Type:</label>
                            <select class="form-select" id="paper-select">
                                <% papers.forEach(paper => { %>
                                    <option value="<%= paper.name.toLowerCase() %>">
                                        <%= paper.name %> - <%= paper.finish %>
                                    </option>
                                <% }); %>
                            </select>
                            <div id="paper-description" class="form-text"></div>
                        </div>

                        <!-- Quantity Selection -->
                        <div class="mb-3">
                            <label for="quantity-select" class="form-label">Quantity:</label>
                            <select class="form-select" id="quantity-select">
                                <option value="50">50 Cards</option>
                                <option value="100">100 Cards</option>
                                <option value="500">500 Cards</option>
                                <option value="1000">1000 Cards</option>
                                <option value="5000">5000 Cards</option>
                            </select>
                        </div>

                        <!-- Upgrades -->
                        <% upgrades.forEach(upgrade => { %>
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="<%= upgrade.name.toLowerCase().replace(/\s+/g, '-') %>">
                                <label class="form-check-label" for="<%= upgrade.name.toLowerCase().replace(/\s+/g, '-') %>">
                                    <%= upgrade.name %>
                                </label>
                                <div class="form-text"><%= upgrade.description %></div>
                            </div>
                        <% }); %>

                        <!-- File Upload -->
                        <div class="mb-3">
                            <label for="file-upload" class="form-label">Upload Your Design</label>
                            <input type="file" class="form-control" id="file-upload" accept="image/*">
                            <div class="form-text">Or choose from our templates below</div>
                        </div>

                        <!-- Pricing -->
                        <div class="mt-4 text-center">
                            <h3>Total: <span id="total-price">$13</span></h3>
                            <p>for <span id="card-quantity">50</span> cards</p>
                            <button class="btn btn-primary btn-lg w-100">Order Now</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Preview</h5>
                        <div class="preview-container">
                            <div id="card-front" class="card-preview">
                                <div class="preview-placeholder">Front of Card</div>
                            </div>
                            <div id="card-back" class="card-preview" style="display: none;">
                                <div class="preview-placeholder">Back of Card</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Templates Section -->
                <div class="mt-4">
                    <h5>Design Templates</h5>
                    <div class="row g-3">
                        <% for(let i = 1; i <= 4; i++) { %>
                            <div class="col-md-6">
                                <div class="card template-card">
                                    <div class="card-body">
                                        Template <%= i %>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="row mt-5">
            <div class="col-12">
                <h2 class="text-center mb-4">Customer Reviews</h2>
                <div class="row">
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="text-warning mb-2">★★★★★</div>
                                <p class="card-text">"Great quality and fast delivery!"</p>
                                <footer class="blockquote-footer">John D.</footer>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="text-warning mb-2">★★★★★</div>
                                <p class="card-text">"Professional finish, love the paper options."</p>
                                <footer class="blockquote-footer">Sarah M.</footer>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="row mt-5">
            <div class="col-12">
                <h2 class="text-center mb-4">Frequently Asked Questions</h2>
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How long does printing take?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Standard orders are printed and shipped within 3-5 business days.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                What file formats do you accept?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                We accept PDF, PNG, and JPG files. For best results, use 300 DPI.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2025 Business Card Printing. All rights reserved.</p>
        </div>
    </footer>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
